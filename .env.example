# SEI NFT Plugin Environment Configuration

# REQUIRED: Your private key for wallet operations (without 0x prefix)
# This key will be used to sign transactions for minting, buying, and selling NFTs
# KEEP THIS SECURE AND NEVER COMMIT IT TO VERSION CONTROL
PRIVATE_KEY=your_64_character_private_key_here

# SEI Blockchain RPC URL (default provided)
SEI_RPC_URL=https://evm-rpc.sei-apis.com

# Magic Eden API URL (default provided)
MAGIC_EDEN_API_URL=https://api-mainnet.magiceden.dev

# NFTScan API URL for fetching NFT data (default provided)
NFTSCAN_API_URL=https://seiapi.nftscan.com

# OPTIONAL: NFTScan API key for higher rate limits
# Get your free API key from https://developer.nftscan.com/
NFTSCAN_API_KEY=your_nftscan_api_key_here

# OPTIONAL: Default NFT contract address for minting
# If not provided, contract address must be specified when minting
NFT_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890

# Example wallet addresses and contract addresses for testing:
# Test Wallet: 0x742d35cc6634c0532925a3b8d6A39E5d4f7c7b76
# Test NFT Contract: 0x50b2bB7c0C0E6c374E8cC5b88e3Ee4DcC5AE1234