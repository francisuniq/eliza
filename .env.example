# SEI NFT Plugin Environment Configuration

# ===============================
# REQUIRED CONFIGURATIONS
# ===============================

# Your SEI wallet private key (64 characters without 0x prefix)
# This key will be used to sign transactions for minting, buying, and selling NFTs
# KEEP THIS SECURE AND NEVER COMMIT IT TO VERSION CONTROL
PRIVATE_KEY=your_64_character_private_key_here

# SEI Blockchain Configuration
SEI_RPC_URL=https://rpc.sei-apis.com
SEI_REST_URL=https://rest.sei-apis.com
SEI_CHAIN_ID=pacific-1

# Testnet Configuration (for development)
# SEI_RPC_URL=https://rpc.arctic-1.seinetwork.io
# SEI_REST_URL=https://rest.arctic-1.seinetwork.io
# SEI_CHAIN_ID=arctic-1

# ===============================
# API INTEGRATIONS
# ===============================

# Magic Eden API Configuration
# Get your API key from: https://docs.magiceden.io/
MAGIC_EDEN_API_KEY=your_magic_eden_api_key_here
MAGIC_EDEN_API_URL=https://api-mainnet.magiceden.dev

# NFTScan API Configuration
# Get your free API key from: https://developer.nftscan.com/
NFTSCAN_API_KEY=your_nftscan_api_key_here
NFTSCAN_API_URL=https://seiapi.nftscan.com

# ===============================
# IPFS STORAGE CONFIGURATION
# ===============================

# Pinata IPFS Service (recommended)
# Get your API keys from: https://app.pinata.cloud/
PINATA_API_KEY=your_pinata_api_key_here
PINATA_SECRET_API_KEY=your_pinata_secret_key_here
PINATA_JWT=your_pinata_jwt_token_here

# Alternative: Filebase IPFS Service
# Get your API keys from: https://filebase.com/
FILEBASE_ACCESS_KEY=your_filebase_access_key_here
FILEBASE_SECRET_KEY=your_filebase_secret_key_here

# Alternative: Web3.Storage
# Get your token from: https://web3.storage/
WEB3_STORAGE_TOKEN=your_web3_storage_token_here

# ===============================
# CONTRACT CONFIGURATIONS
# ===============================

# Default CW721 NFT contract address for minting
# Deploy your own using: seid tx wasm instantiate
CW721_CONTRACT_ADDRESS=sei1234567890abcdef1234567890abcdef12345678

# Default collection metadata
DEFAULT_COLLECTION_NAME=My NFT Collection
DEFAULT_COLLECTION_SYMBOL=MNC
DEFAULT_COLLECTION_DESCRIPTION=A collection of unique digital assets

# ===============================
# THIRDWEB INTEGRATION (OPTIONAL)
# ===============================

# Thirdweb Engine for additional NFT operations
# Get your engine URL from: https://thirdweb.com/engine
THIRDWEB_ENGINE_URL=https://your-engine-id.engine.thirdweb.com
THIRDWEB_ENGINE_ACCESS_TOKEN=your_thirdweb_access_token_here

# ===============================
# MARKETPLACE CONFIGURATIONS
# ===============================

# Default marketplace fees (in basis points, e.g., 250 = 2.5%)
MARKETPLACE_FEE_BASIS_POINTS=250

# Royalty configuration (in basis points)
DEFAULT_ROYALTY_BASIS_POINTS=500

# Price precision (number of decimal places)
PRICE_PRECISION=6

# ===============================
# ANALYTICS & MONITORING
# ===============================

# OpenSea API (for additional NFT data)
OPENSEA_API_KEY=your_opensea_api_key_here

# Coingecko API (for price data)
COINGECKO_API_KEY=your_coingecko_api_key_here

# ===============================
# DEVELOPMENT SETTINGS
# ===============================

# Enable debug logging
DEBUG=true

# Gas price settings (in usei)
GAS_PRICE=0.1usei
GAS_ADJUSTMENT=1.3

# Transaction timeout (in seconds)
TRANSACTION_TIMEOUT=60

# ===============================
# EXAMPLE VALUES FOR TESTING
# ===============================

# Example wallet addresses for testing
# Test Wallet: sei1abc123def456ghi789jkl012mno345pqr678stu
# Test Contract: sei1def456ghi789jkl012mno345pqr678stu901vwx

# Example NFT metadata
# {
#   "name": "Test NFT",
#   "description": "A test NFT for development",
#   "image": "ipfs://QmTestImageHash",
#   "attributes": [
#     {
#       "trait_type": "Color",
#       "value": "Blue"
#     },
#     {
#       "trait_type": "Rarity",
#       "value": "Common"
#     }
