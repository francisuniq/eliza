{
  "name": "sei-nft-plugin",
  "version": "1.0.0",
  "description": "Complete SEI blockchain NFT plugin for minting, buying, selling, and managing NFTs with Magic Eden marketplace integration",
  "main": "sei-nft-plugin.ts",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node sei-nft-plugin.ts",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "compile-contracts": "docker run --rm -v \"$(pwd)\":/code --mount type=volume,source=\"$(basename \"$(pwd)\")_cache\",target=/target --mount type=volume,source=registry_cache,target=/usr/local/cargo/registry cosmwasm/optimizer:0.15.0"
  },
  "keywords": [
    "sei",
    "nft",
    "blockchain",
    "cosmwasm",
    "cw721",
    "magic-eden",
    "ipfs",
    "eliza",
    "plugin"
  ],
  "author": "AI Assistant",
  "license": "MIT",
  "dependencies": {
    "@elizaos/core": "latest",
    "@cosmjs/stargate": "^0.32.2",
    "@cosmjs/proto-signing": "^0.32.2",
    "@cosmjs/cosmwasm-stargate": "^0.32.2",
    "@cosmjs/amino": "^0.32.2",
    "@cosmjs/crypto": "^0.32.2",
    "@cosmjs/encoding": "^0.32.2",
    "@cosmjs/utils": "^0.32.2",
    "ethers": "^6.8.1",
    "axios": "^1.6.2",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1",
    "pinata-sdk": "^2.1.0",
    "ipfs-http-client": "^60.0.1",
    "form-data": "^4.0.0",
    "mime-types": "^2.1.35",
    "big.js": "^6.2.1",
    "bech32": "^2.0.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.9.0",
    "@types/big.js": "^6.2.0",
    "@types/mime-types": "^2.1.4",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0"
  },
  "peerDependencies": {
    "@elizaos/core": "*"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/sei-nft-plugin.git"
  }
}